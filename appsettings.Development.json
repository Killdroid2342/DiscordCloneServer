{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "RateLimiting": {
    "Policies": {
      "auth": {
        "PermitLimit": 60
      },
      "friend": {
        "PermitLimit": 120
      },
      "upload": {
        "PermitLimit": 30
      },
      "abuse": {
        "PermitLimit": 600
      },
      "monitoring": {
        "PermitLimit": 600
      }
    }
  },
  "Monitoring": {
    "SlowRequestThresholdMs": 1500
  }
}
