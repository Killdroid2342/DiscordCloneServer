{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "RateLimiting": {
        "Policies": {
            "auth": {
                "PermitLimit": 12,
                "WindowSeconds": 60,
                "SegmentsPerWindow": 6,
                "QueueLimit": 0
            },
            "friend": {
                "PermitLimit": 20,
                "WindowSeconds": 60,
                "SegmentsPerWindow": 6,
                "QueueLimit": 0
            },
            "upload": {
                "PermitLimit": 8,
                "WindowSeconds": 60,
                "SegmentsPerWindow": 6,
                "QueueLimit": 0
            },
            "abuse": {
                "PermitLimit": 180,
                "WindowSeconds": 60,
                "SegmentsPerWindow": 6,
                "QueueLimit": 0
            },
            "monitoring": {
                "PermitLimit": 120,
                "WindowSeconds": 60,
                "SegmentsPerWindow": 6,
                "QueueLimit": 0
            }
        }
    },
    "Monitoring": {
        "SlowRequestThresholdMs": 1000
    },
    "StaticFiles": {
        "CacheSeconds": 31536000
    },
    "Caching": {
        "LinkPreviewMinutes": 30,
        "PublicServerDiscoverySeconds": 30
    },
    "BackgroundJobs": {
        "Enabled": true,
        "QueueCapacity": 1000
    },
    "SpamDetection": {
        "Enabled": true,
        "BurstMessageLimit": 6,
        "BurstWindowSeconds": 10,
        "DuplicateMessageLimit": 3,
        "DuplicateWindowSeconds": 90,
        "LinkMessageLimit": 4,
        "LinkWindowSeconds": 120,
        "MaxMentionsPerMessage": 12,
        "MaxRepeatedCharacterRun": 24,
        "MaxRepeatedWordRun": 12
    },
    "InviteAbuseDetection": {
        "Enabled": true,
        "WindowMinutes": 10,
        "MaxUsesPerInviteWindow": 10,
        "MaxUsesPerIpWindow": 5,
        "AutoRevokeDetectedInvites": true
    },
    "Cdn": {
        "BaseUrl": ""
    },
    "CleanupJobs": {
        "Enabled": true,
        "IntervalMinutes": 30,
        "StartupDelaySeconds": 15,
        "BatchSize": 500,
        "RevokedSessionRetentionDays": 7,
        "ConsumedVerificationRetentionDays": 1,
        "InactiveInviteRetentionDays": 30,
        "OrphanUploadRetentionHours": 24,
        "CleanupOrphanUploads": true
    },
    "Jwt": {
        "Issuer": "Killdroid2342"
    },
    "WebRtc": {
        "IceServers": [
            {
                "Urls": "stun:stun.l.google.com:19302"
            },
            {
                "Urls": "stun:openrelay.metered.ca:80"
            },
            {
                "Urls": "turn:openrelay.metered.ca:80",
                "Username": "openrelayproject",
                "Credential": "openrelayproject"
            },
            {
                "Urls": "turn:openrelay.metered.ca:443",
                "Username": "openrelayproject",
                "Credential": "openrelayproject"
            },
            {
                "Urls": "turn:openrelay.metered.ca:443?transport=tcp",
                "Username": "openrelayproject",
                "Credential": "openrelayproject"
            }
        ]
    },
    "Verification": {
        "Email": {
            "WebhookUrl": "",
            "ApiKey": ""
        },
        "Sms": {
            "WebhookUrl": "",
            "ApiKey": ""
        }
    },
    "Notifications": {
        "Email": {
            "WebhookUrl": "",
            "ApiKey": ""
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=DiscordClone;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
    }
