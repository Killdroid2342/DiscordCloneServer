{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "RateLimiting": {
    "Policies": {
      "auth": {
        "PermitLimit": 12,
        "WindowSeconds": 60,
        "SegmentsPerWindow": 6,
        "QueueLimit": 0
      },
      "friend": {
        "PermitLimit": 20,
        "WindowSeconds": 60,
        "SegmentsPerWindow": 6,
        "QueueLimit": 0
      },
      "upload": {
        "PermitLimit": 8,
        "WindowSeconds": 60,
        "SegmentsPerWindow": 6,
        "QueueLimit": 0
      },
      "abuse": {
        "PermitLimit": 180,
        "WindowSeconds": 60,
        "SegmentsPerWindow": 6,
        "QueueLimit": 0
      },
      "monitoring": {
        "PermitLimit": 120,
        "WindowSeconds": 60,
        "SegmentsPerWindow": 6,
        "QueueLimit": 0
      }
    }
  },
  "Monitoring": {
    "SlowRequestThresholdMs": 1000
  },
  "Caching": {
    "LinkPreviewMinutes": 30,
    "PublicServerDiscoverySeconds": 30
  },
  "AllowedHosts": "*"
}
